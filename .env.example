# ─── Database (Neon → copy pooled + direct connection strings) ───
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── NextAuth ───
# In prod, set this to your Render URL. Locally use http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Google OAuth (console.cloud.google.com → Credentials) ───
# Authorized redirect URI must include:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://YOURAPP.onrender.com/api/auth/callback/google   (prod)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Access control ───
# Only these emails can sign in. Comma-separated.
ALLOWED_EMAILS="you@gmail.com,friend1@gmail.com,friend2@gmail.com,friend3@gmail.com,friend4@gmail.com"
# Optional: override display names. Format: email=Name,email=Name
USER_DISPLAY_NAMES="you@gmail.com=Krish,friend1@gmail.com=Murtaza,friend2@gmail.com=Stavan,friend3@gmail.com=Parth"
# Admin email — used as addedBy for jobs imported from the CSV seed
ADMIN_SEED_EMAIL="you@gmail.com"
